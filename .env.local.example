# Production: set NEXT_PUBLIC_API_URL to your deployed API (https://...) in Vercel.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Firebase Web SDK (Console → Project settings → Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=podnotes-eed71.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=podnotes-eed71
# New default bucket host is often *.firebasestorage.app (not .appspot.com)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=podnotes-eed71.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
