# --- Local dev (direct to API, optional) ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Production on Vercel (recommended) ---
# Leave NEXT_PUBLIC_API_URL unset or empty so the browser uses same-origin /api (no *.railway.app DNS in the client).
# Set API_URL to your Railway backend (used for Next.js rewrites + server-side fetches). Not exposed to the browser.
# API_URL=https://your-service.up.railway.app
# BACKEND_URL is an alias for API_URL if you prefer that name.

# Firebase Web SDK (Console → Project settings → Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=podnotes-eed71.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=podnotes-eed71
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=podnotes-eed71.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
