# --- Local dev (direct to API, optional) ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Production on Vercel (recommended) ---
# Leave NEXT_PUBLIC_API_URL unset so the browser calls /api/* on your Vercel domain (avoids client DNS to *.railway.app).
# Required on Vercel (Project → Settings → Environment Variables): API_URL=https://your-service.up.railway.app (no trailing slash).
# app/api/[[...path]]/route.ts proxies /api/* on Vercel using API_URL (Node runtime, long maxDuration).
# BACKEND_URL is an alias for API_URL in code. After changing API_URL, redeploy.
#
# Firebase Console → Authentication → Settings → Authorized domains: add your production host
# (e.g. web-xxx.vercel.app and any custom domain).

# Firebase Web SDK (Console → Project settings → Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=podnotes-eed71.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=podnotes-eed71
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=podnotes-eed71.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
